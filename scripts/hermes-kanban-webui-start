#!/usr/bin/env bash
set -euo pipefail
APP_DIR="/home/tjseh0091/workspace/HermesKanban"
HOST="${HERMES_KANBAN_WEBUI_HOST:-127.0.0.1}"
PORT="${HERMES_KANBAN_WEBUI_PORT:-8790}"
REAL_HOME="${HERMES_REAL_HOME:-/home/${USER:-tjseh0091}}"
STATE_DIR="${HERMES_KANBAN_WEBUI_STATE:-$REAL_HOME/.hermes/kanban-webui}"
LOG_PATH="${HERMES_KANBAN_WEBUI_LOG:-$REAL_HOME/.hermes/logs/kanban-webui.log}"
PID_FILE="$STATE_DIR/kanban-webui.pid"
mkdir -p "$STATE_DIR" "$(dirname "$LOG_PATH")"
if [[ -f "$PID_FILE" ]]; then
  old_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
    echo "KanbanWebUI already running: pid=$old_pid url=http://$HOST:$PORT"
    exit 0
  fi
fi
cd "$APP_DIR"
export HERMES_AGENT_ROOT="${HERMES_AGENT_ROOT:-/home/tjseh0091/.hermes/hermes-agent}"
export HERMES_KANBAN_WEBUI_HOST="$HOST"
export HERMES_KANBAN_WEBUI_PORT="$PORT"
export HERMES_KANBAN_WEBUI_STATE="$STATE_DIR"
export HERMES_KANBAN_WEBUI_LOG="$LOG_PATH"
nohup /home/tjseh0091/.local/bin/uv run python server.py --host "$HOST" --port "$PORT" >> "$LOG_PATH" 2>&1 &
pid=$!
echo "$pid" > "$PID_FILE"
sleep 1
if kill -0 "$pid" 2>/dev/null; then
  echo "KanbanWebUI started: pid=$pid url=http://$HOST:$PORT log=$LOG_PATH"
else
  echo "KanbanWebUI failed to start; see $LOG_PATH" >&2
  exit 1
fi
