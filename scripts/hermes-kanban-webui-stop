#!/usr/bin/env bash
set -euo pipefail
REAL_HOME="${HERMES_REAL_HOME:-/home/${USER:-tjseh0091}}"
STATE_DIR="${HERMES_KANBAN_WEBUI_STATE:-$REAL_HOME/.hermes/kanban-webui}"
PID_FILE="$STATE_DIR/kanban-webui.pid"
if [[ ! -f "$PID_FILE" ]]; then
  echo "KanbanWebUI is not running (no pid file)"
  exit 0
fi
pid="$(cat "$PID_FILE" 2>/dev/null || true)"
if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
  rm -f "$PID_FILE"
  echo "KanbanWebUI is not running"
  exit 0
fi
kill "$pid"
for _ in {1..20}; do
  if ! kill -0 "$pid" 2>/dev/null; then
    rm -f "$PID_FILE"
    echo "KanbanWebUI stopped"
    exit 0
  fi
  sleep 0.2
done
kill -9 "$pid" 2>/dev/null || true
rm -f "$PID_FILE"
echo "KanbanWebUI force-stopped"
